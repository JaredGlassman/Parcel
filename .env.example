# ── Required ─────────────────────────────────────────────────────────────────
# Get from: https://console.anthropic.com/
# Used for: satellite image analysis (fencing, pool, solar detection)
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Optional — better satellite imagery ──────────────────────────────────────
# Get from: https://console.cloud.google.com/ → Maps Static API
# Without this, free ESRI imagery is used (works fine, slightly lower resolution)
GOOGLE_MAPS_API_KEY=AIzaSy...
